### Step 5: Add a Multi-Issue Setup Helper

Below the existing `baseOpts` helper function (around line 180), add a helper function that configures the mocks for a multi-issue scenario:

```typescript
/**
 * Configure mocks for a two-issue scenario that triggers worktree mode.
 * Must be called inside a test or beforeEach after vi.clearAllMocks().
 */
async function setupMultiIssueScenario() {
  const { fetchItemsById, writeItemsToTempDir } = await import("../orchestrator/datasource-helpers.js");
  const { parseTaskFile } = await import("../parser.js");

  // Two issues returned from fetch
  vi.mocked(fetchItemsById).mockResolvedValue([
    {
      number: "1",
      title: "Test",
      body: "# Test\n\n- [ ] Implement the feature",
      labels: [],
      state: "open",
      url: "https://example.com/1",
      comments: [],
      acceptanceCriteria: "",
    },
    {
      number: "2",
      title: "Feature",
      body: "# Feature\n\n- [ ] Add the feature",
      labels: [],
      state: "open",
      url: "https://example.com/2",
      comments: [],
      acceptanceCriteria: "",
    },
  ]);

  // Two files written to temp dir
  vi.mocked(writeItemsToTempDir).mockResolvedValue({
    files: ["/tmp/dispatch-test/1-test.md", "/tmp/dispatch-test/2-feature.md"],
    issueDetailsByFile: new Map([
      ["/tmp/dispatch-test/1-test.md", {
        number: "1",
        title: "Test",
        body: "# Test\n\n- [ ] Implement the feature",
        labels: [],
        state: "open",
        url: "https://example.com/1",
        comments: [],
        acceptanceCriteria: "",
      }],
      ["/tmp/dispatch-test/2-feature.md", {
        number: "2",
        title: "Feature",
        body: "# Feature\n\n- [ ] Add the feature",
        labels: [],
        state: "open",
        url: "https://example.com/2",
        comments: [],
        acceptanceCriteria: "",
      }],
    ]),
  });

  // Parse returns the right fixture based on file path
  vi.mocked(parseTaskFile).mockImplementation(async (file: string) => {
    if (file.includes("2-feature")) return TASK_FILE_FIXTURE_2;
    return TASK_FILE_FIXTURE;
  });

  // createWorktree returns paths based on the issue filename
  vi.mocked(createWorktree).mockImplementation(async (_repoRoot: string, issueFilename: string) => {
    if (issueFilename.includes("2-feature")) return "/tmp/test/.dispatch/worktrees/2-feature";
    return "/tmp/test/.dispatch/worktrees/1-test";
  });

  // worktreeName returns name based on filename
  vi.mocked(worktreeName).mockImplementation((issueFilename: string) => {
    if (issueFilename.includes("2-feature")) return "2-feature";
    return "1-test";
  });

  // buildBranchName returns different names per issue
  const ds = vi.mocked(getDatasource)("md") as unknown as Datasource;
  vi.mocked(ds.buildBranchName).mockImplementation((num: string) => {
    return `testuser/dispatch/${num}-test`;
  });
}
```

### Step 6: Add the Worktree Test Suite

At the bottom of the test file (after the existing `"commitAllChanges safety-net"` describe block, before the closing), add the following test suite:

```typescript
// ─── Worktree-based parallel execution ──────────────────────────────

describe("worktree-based parallel execution", () => {
  beforeEach(async () => {
    vi.useFakeTimers();
    vi.clearAllMocks();
    mocks.mockExecute.mockResolvedValue({
      success: true,
      dispatchResult: { task: TASK_FIXTURE, success: true },
      elapsedMs: 100,
    });
    mocks.mockPlan.mockImplementation(() =>
      new Promise<PlanResult>((resolve) => {
        setTimeout(() => resolve({ prompt: "Execute step 1", success: true }), 50);
      }),
    );
  });

  afterEach(() => {
    vi.useRealTimers();
  });

  it("creates a worktree for each issue file when conditions are met", async () => {
    await setupMultiIssueScenario();

    // Need per-task dispatchResult to match the right task
    mocks.mockExecute.mockImplementation(async ({ task }: { task: Task }) => ({
      success: true,
      dispatchResult: { task, success: true },
      elapsedMs: 100,
    }));

    const resultPromise = runDispatchPipeline(
      baseOpts({ issueIds: ["1", "2"], noBranch: false, noWorktree: false }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    const result = await resultPromise;

    expect(result.completed).toBe(2);
    expect(result.failed).toBe(0);
    expect(createWorktree).toHaveBeenCalledTimes(2);
    expect(createWorktree).toHaveBeenCalledWith(
      "/tmp/test",
      "/tmp/dispatch-test/1-test.md",
      expect.stringContaining("1"),
    );
    expect(createWorktree).toHaveBeenCalledWith(
      "/tmp/test",
      "/tmp/dispatch-test/2-feature.md",
      expect.stringContaining("2"),
    );
  });

  it("passes worktree path as cwd to executor", async () => {
    await setupMultiIssueScenario();

    mocks.mockExecute.mockImplementation(async ({ task }: { task: Task }) => ({
      success: true,
      dispatchResult: { task, success: true },
      elapsedMs: 100,
    }));

    const resultPromise = runDispatchPipeline(
      baseOpts({ issueIds: ["1", "2"], noBranch: false, noWorktree: false }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    await resultPromise;

    // Verify executor was called with worktree paths, NOT the main repo cwd
    const executeCalls = mocks.mockExecute.mock.calls;
    expect(executeCalls).toHaveLength(2);

    const cwds = executeCalls.map((call) => call[0].cwd);
    expect(cwds).toContain("/tmp/test/.dispatch/worktrees/1-test");
    expect(cwds).toContain("/tmp/test/.dispatch/worktrees/2-feature");
    // Must NOT contain the original cwd
    expect(cwds).not.toContain("/tmp/test");
  });

  it("calls removeWorktree after issue completion", async () => {
    await setupMultiIssueScenario();

    mocks.mockExecute.mockImplementation(async ({ task }: { task: Task }) => ({
      success: true,
      dispatchResult: { task, success: true },
      elapsedMs: 100,
    }));

    const resultPromise = runDispatchPipeline(
      baseOpts({ issueIds: ["1", "2"], noBranch: false, noWorktree: false }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    await resultPromise;

    expect(removeWorktree).toHaveBeenCalledTimes(2);
    expect(removeWorktree).toHaveBeenCalledWith("/tmp/test", "/tmp/dispatch-test/1-test.md");
    expect(removeWorktree).toHaveBeenCalledWith("/tmp/test", "/tmp/dispatch-test/2-feature.md");
  });

  it("registers worktree cleanup with registerCleanup", async () => {
    await setupMultiIssueScenario();

    mocks.mockExecute.mockImplementation(async ({ task }: { task: Task }) => ({
      success: true,
      dispatchResult: { task, success: true },
      elapsedMs: 100,
    }));

    const resultPromise = runDispatchPipeline(
      baseOpts({ issueIds: ["1", "2"], noBranch: false, noWorktree: false }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    await resultPromise;

    // registerCleanup is called once for the provider instance + once per worktree
    // Provider cleanup is at line 165, worktree cleanups at line 227
    const cleanupCalls = vi.mocked(registerCleanup).mock.calls;
    // At least 3: 1 provider + 2 worktrees
    expect(cleanupCalls.length).toBeGreaterThanOrEqual(3);
  });

  it("sets worktree name on TUI task state", async () => {
    await setupMultiIssueScenario();

    mocks.mockExecute.mockImplementation(async ({ task }: { task: Task }) => ({
      success: true,
      dispatchResult: { task, success: true },
      elapsedMs: 100,
    }));

    const resultPromise = runDispatchPipeline(
      baseOpts({ issueIds: ["1", "2"], noBranch: false, noWorktree: false }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    await resultPromise;

    // worktreeName should have been called to tag the TUI tasks
    expect(worktreeName).toHaveBeenCalled();
  });

  it("does not use worktrees when noWorktree is true (--no-worktree)", async () => {
    await setupMultiIssueScenario();

    mocks.mockExecute.mockImplementation(async ({ task }: { task: Task }) => ({
      success: true,
      dispatchResult: { task, success: true },
      elapsedMs: 100,
    }));

    const resultPromise = runDispatchPipeline(
      baseOpts({ issueIds: ["1", "2"], noBranch: false, noWorktree: true }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    const result = await resultPromise;

    expect(result.completed).toBe(2);
    // Worktree functions should NOT be called
    expect(createWorktree).not.toHaveBeenCalled();
    expect(removeWorktree).not.toHaveBeenCalled();

    // Serial branch mode should be used instead
    const ds = vi.mocked(getDatasource)("md") as unknown as Datasource;
    expect(ds.createAndSwitchBranch).toHaveBeenCalled();
    expect(ds.switchBranch).toHaveBeenCalled();
  });

  it("falls back to serial mode for single-issue runs", async () => {
    // Default single-issue setup (don't call setupMultiIssueScenario)

    const resultPromise = runDispatchPipeline(
      baseOpts({ noBranch: false, noWorktree: false }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    const result = await resultPromise;

    expect(result.completed).toBe(1);
    // Single issue = tasksByFile.size === 1 → serial mode
    expect(createWorktree).not.toHaveBeenCalled();

    // Serial branch lifecycle should be used
    const ds = vi.mocked(getDatasource)("md") as unknown as Datasource;
    expect(ds.createAndSwitchBranch).toHaveBeenCalled();
  });

  it("passes worktree cwd to commitAllChanges", async () => {
    await setupMultiIssueScenario();

    mocks.mockExecute.mockImplementation(async ({ task }: { task: Task }) => ({
      success: true,
      dispatchResult: { task, success: true },
      elapsedMs: 100,
    }));

    const resultPromise = runDispatchPipeline(
      baseOpts({ issueIds: ["1", "2"], noBranch: false, noWorktree: false }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    await resultPromise;

    const ds = vi.mocked(getDatasource)("md") as unknown as Datasource;
    const commitCalls = vi.mocked(ds.commitAllChanges).mock.calls;
    expect(commitCalls.length).toBe(2);
    // Each commit should use the worktree cwd, not the main repo cwd
    const commitCwds = commitCalls.map((call) => call[1].cwd);
    expect(commitCwds).toContain("/tmp/test/.dispatch/worktrees/1-test");
    expect(commitCwds).toContain("/tmp/test/.dispatch/worktrees/2-feature");
  });

  it("does not call switchBranch in worktree mode", async () => {
    await setupMultiIssueScenario();

    mocks.mockExecute.mockImplementation(async ({ task }: { task: Task }) => ({
      success: true,
      dispatchResult: { task, success: true },
      elapsedMs: 100,
    }));

    const resultPromise = runDispatchPipeline(
      baseOpts({ issueIds: ["1", "2"], noBranch: false, noWorktree: false }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    await resultPromise;

    // In worktree mode, there's no need to switch branches back
    const ds = vi.mocked(getDatasource)("md") as unknown as Datasource;
    expect(ds.switchBranch).not.toHaveBeenCalled();
    expect(ds.createAndSwitchBranch).not.toHaveBeenCalled();
  });

  it("continues gracefully when worktree creation fails", async () => {
    await setupMultiIssueScenario();

    // Make createWorktree fail for the first issue
    vi.mocked(createWorktree)
      .mockRejectedValueOnce(new Error("worktree add failed"))
      .mockResolvedValueOnce("/tmp/test/.dispatch/worktrees/2-feature");

    mocks.mockExecute.mockImplementation(async ({ task }: { task: Task }) => ({
      success: true,
      dispatchResult: { task, success: true },
      elapsedMs: 100,
    }));

    const resultPromise = runDispatchPipeline(
      baseOpts({ issueIds: ["1", "2"], noBranch: false, noWorktree: false }),
      "/tmp/test",
    );
    await vi.advanceTimersByTimeAsync(50);
    await vi.runAllTimersAsync();

    const result = await resultPromise;

    // Should still complete tasks (falls back to main cwd for the failed worktree)
    expect(result.completed).toBe(2);
    expect(vi.mocked(log.warn)).toHaveBeenCalledWith(
      expect.stringContaining("Could not create branch"),
    );
  });
});
```

